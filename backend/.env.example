# Django Settings
DJANGO_SETTINGS_MODULE=TradeSimulator.settings
SECRET_KEY=your-secret-key-generate-a-strong-random-string
DEBUG=False
ALLOWED_HOSTS=.railway.app,.up.railway.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.railway.app,https://*.up.railway.app

# Database (Railway will provide this in production)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Local development database fallback when DATABASE_URL is not set
DB_NAME=privateiv
DB_USER=your-local-postgres-user
DB_PASSWORD=your-local-postgres-password
DB_HOST=localhost
DB_PORT=5432

# Redis/Celery (Railway will provide this)
CELERY_BROKER_URL=redis://host:port/0
CELERY_RESULT_BACKEND=redis://host:port/0

# API Keys (get from providers)
BVL_API_KEY=your-bvl-api-key
FMP_API=your-fmp-api-key

# Datadog (optional - you already have this configured)
DD_API_KEY=your-datadog-api-key
DD_SITE=datadoghq.com
DD_ENV=production
DD_SERVICE=privateiv-api
DD_VERSION=1.0.0

# CORS Origins (update with your Railway frontend URL)
CORS_ALLOWED_ORIGINS=https://your-frontend.railway.app,http://localhost:5173
